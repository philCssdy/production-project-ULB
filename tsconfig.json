{
  "compilerOptions": {
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "ESNext",
    "target": "ES5",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "node",

    "baseUrl": ".",
    "paths": {
      "shared/*": ["src/shared/*"],
      "widgets/*": ["src/widgets/*"],
      "pages/*": ["src/pages/*"],
      "entities/*": ["src/entities/*"],
      "features/*": ["src/features/*"]
    },

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["jest", "@testing-library/jest-dom"]
  },

  "include": ["src", ".config"]
}
