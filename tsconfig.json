{
  "compilerOptions": {
    "outDir": "./dist/",
    // необходимость явного указания типа (чтобы не было any, явно указать any можно)
    "noImplicitAny": true,
    "module": "ESNext",
    // в какую спецификацию компилируем в es5
    "target": "ES5",
    "jsx": "react-jsx",
    // копилирует не только ts файлы но и js
    "allowJs": true,
    "moduleResolution": "node",
    // для абсолютного ипорта (может и не пригодится vsсправляется сам)
    "baseUrl": ".",

    // esModuleInterop позваляет работать с пакетами которые использует
    // comon js как с обычными пакетами так и с помощью ipmort (require() module.export = > common js)

    //allowSyntheticDefaultImports ипорты без * as (просто писать как обычные импорты)
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "ts-node": {
    "compilerOptions": {
      "module": "Commonjs"
    }
  }
}
